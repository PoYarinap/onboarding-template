# ─────────────────────────────────────────────────────────────────────────────
# Frontend environment. Copy to `.env`. Only VITE_-prefixed vars are exposed to
# the client bundle (import.meta.env). Leave a var empty/omitted to disable the
# feature it gates. NEVER put server secrets here — these values ship to browsers.
# ─────────────────────────────────────────────────────────────────────────────

# API base URL. Empty = same-origin (the Vite dev server proxies /api → :3000).
VITE_API_URL=http://localhost:3000

# Google OAuth client id — enables the "Login with Google" button (optional)
VITE_GOOGLE_CLIENT_ID=

# Cloudflare Turnstile site key — enables the login CAPTCHA (optional)
VITE_TURNSTILE_SITE_KEY=

# Backend target for Docker / deployment tooling (not read by the app bundle)
BACKEND_URL=http://localhost:3000
BACKEND_HOST=localhost
